# Google API Credentials (For Server-side Google Drive/Sheets integration)
GOOGLE_CLIENT_EMAIL=your-service-account-email@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Supabase Credentials (For Client-side DB Sync integration)
# These MUST be prefixed with VITE_ to be accessible in the React client-side application
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
